{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "title": "Security Dashboard",
  "uid": "security-dashboard",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["security", "alerts"],
  "panels": [

    {
      "id": 1,
      "title": "Unauthorized Requests (401) Rate",
      "description": "Rate of HTTP 401 responses — possible brute force attack",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=\"401\"}[5m])",
          "legendFormat": "{{ application }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 2,
      "title": "Forbidden Requests (403) Rate",
      "description": "Rate of HTTP 403 responses — possible privilege escalation",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=\"403\"}[5m])",
          "legendFormat": "{{ application }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 3,
      "title": "Total 401 Requests",
      "description": "Total unauthorized requests since startup",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(http_server_requests_seconds_count{status=\"401\"})",
          "legendFormat": "Total 401s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 4,
      "title": "Total 403 Requests",
      "description": "Total forbidden requests since startup",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(http_server_requests_seconds_count{status=\"403\"})",
          "legendFormat": "Total 403s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 5,
      "title": "Total 5xx Errors",
      "description": "Total server errors since startup",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(http_server_requests_seconds_count{status=~\"5..\"})",
          "legendFormat": "Total 5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 6,
      "title": "Request Rate per Service",
      "description": "Total request rate — spike may indicate DDoS",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[1m])",
          "legendFormat": "{{ application }} - {{ uri }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 7,
      "title": "Security Logs",
      "description": "Live security-related log entries from all services",
      "type": "logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "{layer=\"application\"} |= \"401\" or {layer=\"application\"} |= \"403\" or {layer=\"application\"} |= \"ERROR\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "datasource": "Loki"
    }

  ]
}