{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },

  "title": "Application Dashboard",
  "uid": "application-dashboard",
  "schemaVersion": 36,
  "version": 2,

  "refresh": "30s",

  "time": {
    "from": "now-1h",
    "to": "now"
  },

  "tags": [
    "application",
    "performance"
  ],

  "panels": [

    {
      "id": 1,
      "title": "Average Response Time",
      "description": "Average HTTP response time per application service.",
      "type": "timeseries",

      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "sum by(application)(rate(http_server_requests_seconds_sum{layer=\"application\"}[5m])) / sum by(application)(rate(http_server_requests_seconds_count{layer=\"application\"}[5m]))",
          "legendFormat": "{{application}}"
        }
      ],

      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 2, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "id": 2,
      "title": "Current Request Rate",
      "description": "Current HTTP requests per second for each service.",
      "type": "timeseries",

      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "sum by(application)(rate(http_server_requests_seconds_count{layer=\"application\"}[1m]))",
          "legendFormat": "{{application}}"
        }
      ],

      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },

    {
      "id": 3,
      "title": "HTTP 5xx Error Rate",
      "description": "Percentage of server errors generated by each service.",
      "type": "timeseries",

      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "100 * sum by(application)(rate(http_server_requests_seconds_count{layer=\"application\",status=~\"5..\"}[5m])) / sum by(application)(rate(http_server_requests_seconds_count{layer=\"application\"}[5m]))",
          "legendFormat": "{{application}}"
        }
      ],

      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "id": 4,
      "title": "Database Connection Pool Usage",
      "description": "Percentage of HikariCP connections currently in use.",
      "type": "timeseries",

      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "100 * hikaricp_connections_active{layer=\"application\"} / hikaricp_connections_max{layer=\"application\"}",
          "legendFormat": "{{application}}"
        }
      ],

      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "title": "JVM Heap Usage",
      "description": "Heap memory usage for each service.",
      "type": "timeseries",

      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "100 * jvm_memory_used_bytes{layer=\"application\",area=\"heap\"} / jvm_memory_max_bytes{layer=\"application\",area=\"heap\"}",
          "legendFormat": "{{application}}"
        }
      ],

      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },

    {
      "id": 6,
      "title": "Live JVM Threads",
      "description": "Current number of JVM threads per service.",
      "type": "timeseries",

      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "jvm_threads_live_threads{layer=\"application\"}",
          "legendFormat": "{{application}}"
        }
      ],

      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },

    {
      "id": 7,
      "title": "Top Slow Endpoints (95th Percentile)",
      "description": "Endpoints with the highest response latency.",
      "type": "table",

      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 8
      },

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by(uri,le)(rate(http_server_requests_seconds_bucket{layer=\"application\"}[5m]))))"
        }
      ]
    },

    {
      "id": 8,
      "title": "Application Logs",
      "description": "Live logs from all application services.",
      "type": "logs",

      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 10
      },

      "datasource": "Loki",

      "targets": [
        {
          "expr": "{layer=\"application\"}"
        }
      ],

      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }

  ]
}