{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "title": "System Overview",
  "uid": "system-overview",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["system", "overview"],
  "panels": [

    {
      "id": 1,
      "title": "Services Status",
      "description": "UP/DOWN status for all microservices",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{ application }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "datasource": "Prometheus"
    },

    {
      "id": 2,
      "title": "CPU Usage per Service",
      "description": "Process CPU usage percentage per microservice",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_cpu_usage * 100",
          "legendFormat": "{{ application }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 3,
      "title": "Memory Usage per Service",
      "description": "JVM Heap memory usage per microservice",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"} / jvm_memory_max_bytes{area=\"heap\"} * 100",
          "legendFormat": "{{ application }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 4,
      "title": "Total Active Services",
      "description": "Number of services currently UP",
      "type": "stat",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Services UP"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 5,
      "title": "Total Down Services",
      "description": "Number of services currently DOWN",
      "type": "stat",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(up == 0) OR vector(0)",
          "legendFormat": "Services DOWN"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "datasource": "Prometheus"
    },

    {
      "id": 6,
      "title": "JVM Threads per Service",
      "description": "Number of active JVM threads per service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{ application }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "datasource": "Prometheus"
    }

  ]
}